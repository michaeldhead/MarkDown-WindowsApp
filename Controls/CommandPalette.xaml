<UserControl x:Class="GHSMarkdownEditor.Controls.CommandPalette"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:GHSMarkdownEditor.ViewModels"
             IsVisibleChanged="OnIsVisibleChanged">

    <UserControl.Resources>

        <!-- DataTemplate for category header rows -->
        <DataTemplate DataType="{x:Type vm:PaletteHeader}">
            <TextBlock Text="{Binding Category}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="12 8 12 2"
                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"/>
        </DataTemplate>

        <!-- DataTemplate for selectable result rows -->
        <DataTemplate DataType="{x:Type vm:PaletteItem}">
            <StackPanel Margin="4 2">
                <TextBlock Text="{Binding Title}"
                           FontSize="13"/>
                <TextBlock Text="{Binding Subtitle}"
                           FontSize="11"
                           Opacity="0.55">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Subtitle}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Subtitle}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <!-- Container style: disable/no-highlight for headers; normal hover for items -->
        <Style x:Key="PaletteContainerStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8 3"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHeader}" Value="True">
                    <Setter Property="IsEnabled"  Value="False"/>
                    <Setter Property="Focusable"  Value="False"/>
                    <Setter Property="Padding"    Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <!-- Drop shadow + rounded card sitting at the top of the content area -->
    <materialDesign:Card Margin="40 8 40 0"
                         Padding="0"
                         materialDesign:ElevationAssist.Elevation="Dp8"
                         UniformCornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" MaxHeight="400"/>
            </Grid.RowDefinitions>

            <!-- Search input row -->
            <Grid Grid.Row="0" Margin="12 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:PackIcon Kind="Magnify"
                                         Grid.Column="0"
                                         VerticalAlignment="Center"
                                         Opacity="0.55"
                                         Margin="0 0 8 0"/>

                <TextBox x:Name="searchBox"
                         Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Search commands, tabs, headings…"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         FontSize="14"
                         BorderThickness="0"
                         Padding="0 4"
                         KeyDown="SearchBox_KeyDown"/>
            </Grid>

            <Separator Grid.Row="0" VerticalAlignment="Bottom" Margin="0 36 0 0"/>

            <!-- Results list -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ListBox x:Name="resultsList"
                         ItemsSource="{Binding FilteredItems}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         ItemContainerStyle="{StaticResource PaletteContainerStyle}"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="ResultsList_SelectionChanged"
                         MouseDoubleClick="ResultsList_MouseDoubleClick"
                         Margin="0 4 0 8"/>
            </ScrollViewer>

        </Grid>
    </materialDesign:Card>
</UserControl>
