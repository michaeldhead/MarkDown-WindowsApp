<UserControl x:Class="GHSMarkdownEditor.Controls.ToolbarRibbon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="RibbonButtonStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignIconButton}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="32"/>
        </Style>
        <Style x:Key="RibbonSeparatorStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="4 6"/>
            <Setter Property="Fill" Value="{DynamicResource MaterialDesign.Brush.ForegroundLight}"/>
            <Setter Property="Opacity" Value="0.35"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource MaterialDesign.Brush.Background}"
            BorderThickness="0 0 0 1"
            BorderBrush="{DynamicResource MaterialDesign.Brush.ForegroundLight}">

        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="4 0">

            <StackPanel Orientation="Horizontal"
                        Height="40"
                        VerticalAlignment="Center">

                <!-- ── Group 1: File ─────────────────────────────────────── -->
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding NewTabCommand}"
                        ToolTip="New (Ctrl+N)">
                    <materialDesign:PackIcon Kind="FileOutline" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding OpenFileCommand}"
                        ToolTip="Open (Ctrl+O)">
                    <materialDesign:PackIcon Kind="FolderOpen" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding SaveFileCommand}"
                        ToolTip="Save (Ctrl+S)">
                    <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding SaveFileAsCommand}"
                        ToolTip="Save As (Ctrl+Shift+S)">
                    <materialDesign:PackIcon Kind="ContentSaveEdit" Width="18" Height="18"/>
                </Button>

                <Rectangle Style="{StaticResource RibbonSeparatorStyle}"/>

                <!-- ── Group 2: Format ───────────────────────────────────── -->
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding BoldCommand}"
                        ToolTip="Bold (Ctrl+B)">
                    <materialDesign:PackIcon Kind="FormatBold" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding ItalicCommand}"
                        ToolTip="Italic (Ctrl+I)">
                    <materialDesign:PackIcon Kind="FormatItalic" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding StrikethroughCommand}"
                        ToolTip="Strikethrough">
                    <materialDesign:PackIcon Kind="FormatStrikethroughVariant" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding InlineCodeCommand}"
                        ToolTip="Inline Code">
                    <materialDesign:PackIcon Kind="CodeTags" Width="18" Height="18"/>
                </Button>

                <Rectangle Style="{StaticResource RibbonSeparatorStyle}"/>

                <!-- ── Group 3: Headings ─────────────────────────────────── -->
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding H1Command}"
                        ToolTip="Heading 1">
                    <materialDesign:PackIcon Kind="FormatHeader1" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding H2Command}"
                        ToolTip="Heading 2">
                    <materialDesign:PackIcon Kind="FormatHeader2" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding H3Command}"
                        ToolTip="Heading 3">
                    <materialDesign:PackIcon Kind="FormatHeader3" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding H4Command}"
                        ToolTip="Heading 4">
                    <materialDesign:PackIcon Kind="FormatHeader4" Width="18" Height="18"/>
                </Button>

                <Rectangle Style="{StaticResource RibbonSeparatorStyle}"/>

                <!-- ── Group 4: Lists ────────────────────────────────────── -->
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding BulletListCommand}"
                        ToolTip="Bullet List">
                    <materialDesign:PackIcon Kind="FormatListBulleted" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding NumberedListCommand}"
                        ToolTip="Numbered List">
                    <materialDesign:PackIcon Kind="FormatListNumbered" Width="18" Height="18"/>
                </Button>

                <Rectangle Style="{StaticResource RibbonSeparatorStyle}"/>

                <!-- ── Group 5: Insert ───────────────────────────────────── -->
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding CodeBlockCommand}"
                        ToolTip="Code Block">
                    <materialDesign:PackIcon Kind="CodeBraces" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding TableCommand}"
                        ToolTip="Insert Table">
                    <materialDesign:PackIcon Kind="Table" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding HorizontalRuleCommand}"
                        ToolTip="Horizontal Rule">
                    <materialDesign:PackIcon Kind="Minus" Width="18" Height="18"/>
                </Button>
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding LinkCommand}"
                        ToolTip="Insert Link">
                    <materialDesign:PackIcon Kind="Link" Width="18" Height="18"/>
                </Button>

                <Rectangle Style="{StaticResource RibbonSeparatorStyle}"/>

                <!-- ── Detach Preview (visible in Split/Preview mode or when detached) -->
                <Button Style="{StaticResource RibbonButtonStyle}"
                        Command="{Binding ToggleDetachPreviewCommand}"
                        ToolTip="Detach Preview to separate window"
                        Visibility="{Binding ShowDetachPreviewButton,
                                     Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="OpenInNew" Width="18" Height="18"/>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
