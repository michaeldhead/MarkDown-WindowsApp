<UserControl x:Class="GHSMarkdownEditor.Controls.OutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:GHSMarkdownEditor.Converters"
             xmlns:models="clr-namespace:GHSMarkdownEditor.Models">

    <UserControl.Resources>
        <conv:DoubleToLeftThicknessConverter x:Key="IndentConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="12 6">
            <TextBlock Text="Outline"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"/>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <TextBlock Text="No headings found."
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HeadingItems.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Heading list -->
            <ListBox ItemsSource="{Binding HeadingItems}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Background="Transparent">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:HeadingItem}">
                        <Button Command="{Binding DataContext.ScrollToHeadingCommand,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8 4"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       FontSize="12"
                                       Margin="{Binding Indent, Converter={StaticResource IndentConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBold}" Value="True">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
