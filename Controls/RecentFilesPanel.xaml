<UserControl x:Class="GHSMarkdownEditor.Controls.RecentFilesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:GHSMarkdownEditor.Models">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="12 6">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Command="{Binding ClearRecentFilesCommand}"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Width="24" Height="24" Padding="0"
                        ToolTip="Clear recent files"
                        Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}">
                    <materialDesign:PackIcon Kind="DeleteSweep" Width="14" Height="14"/>
                </Button>
                <TextBlock Text="Recent Files"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesign.Brush.Primary.Foreground}"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <TextBlock Text="No recent files."
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecentFiles.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- File list -->
            <ListBox ItemsSource="{Binding RecentFiles}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Background="Transparent">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:RecentFileItem}">
                        <Button Command="{Binding DataContext.OpenRecentFileCommand,
                                         RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Padding="8 4"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                ToolTip="{Binding FilePath}">
                            <TextBlock Text="{Binding FileName}"
                                       FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                <Setter Property="Opacity" Value="0.45"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
