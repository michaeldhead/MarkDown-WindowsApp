<UserControl x:Class="GHSMarkdownEditor.Controls.AboutDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Width="420">

    <StackPanel Margin="24 20 24 16">

        <!-- App name & version -->
        <TextBlock Text="GHS Markdown Editor"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                   Margin="0 0 0 4"/>
        <TextBlock Text="Version 1.0.0"
                   FontSize="13"
                   Opacity="0.6"
                   Margin="0 0 0 12"/>

        <!-- Description -->
        <TextBlock Text="A modern Markdown editor for Windows built with WPF, AvalonEdit, and WebView2."
                   TextWrapping="Wrap"
                   Margin="0 0 0 16"/>

        <!-- Credit -->
        <TextBlock Text="A Head &amp; CC Production · Mike &amp; The Machine · 2026"
                   FontSize="13"
                   Opacity="0.6"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 20"/>

        <!-- Close button -->
        <Button Content="CLOSE"
                Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                Style="{StaticResource MaterialDesignFlatButton}"
                HorizontalAlignment="Right"
                Margin="0"/>

    </StackPanel>
</UserControl>
