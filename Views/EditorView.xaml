<UserControl x:Class="GHSMarkdownEditor.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit">
    <avalonEdit:TextEditor x:Name="textEditor"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"
                           ShowLineNumbers="True"
                           WordWrap="{Binding EditorWordWrap}"
                           FontFamily="Consolas"
                           FontSize="{Binding EditorFontSize}"
                           Background="{DynamicResource MaterialDesign.Brush.Background}"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                           LineNumbersForeground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                           Padding="4"/>
</UserControl>
